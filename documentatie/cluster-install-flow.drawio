        </mxCell>

        <!-- Box 8: retrieve-kubeconfig -->
        <mxCell id="16" value="Role: retrieve-kubeconfig&#xa;(fetch k3s.yaml)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=0;arcSize=20;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="160" y="740" width="280" height="50" as="geometry" />
        </mxCell>

        <!-- Arrow 8→9 -->
        <mxCell id="17" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;" edge="1" source="16" target="18" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Box 9: master-install -->
        <mxCell id="18" value="Role: master-install&#xa;(join additional masters)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=0;arcSize=20;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="160" y="840" width="280" height="50" as="geometry" />
