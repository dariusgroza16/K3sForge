              <mxPoint x="500" y="465" />
              <mxPoint x="500" y="55" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Section labels -->
        <mxCell id="30" value="Frontend" style="text;html=1;fontSize=11;fontStyle=3;fontColor=#6c8ebf;align=left;" vertex="1" parent="1">
