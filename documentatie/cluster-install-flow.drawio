          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Box 7: master-primordial-install -->
        <mxCell id="14" value="Role: master-primordial-install&#xa;(initialize K3s cluster)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=0;arcSize=20;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="160" y="640" width="280" height="50" as="geometry" />
