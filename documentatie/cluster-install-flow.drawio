<mxfile host="app.diagrams.net" agent="K3sForge" version="24.0.0">
  <diagram name="Cluster Install Flow" id="cluster-install-flow">
    <mxGraphModel dx="1200" dy="1600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Box 1: User creates inventory -->
        <mxCell id="2" value="User creates inventory&#xa;in Web UI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;arcSize=20;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="160" y="30" width="280" height="50" as="geometry" />
        </mxCell>

        <!-- Arrow 1→2 -->
        <mxCell id="3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;" edge="1" source="2" target="4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Box 2: Flask API generates inventory -->
        <mxCell id="4" value="Flask API receives data&#xa;(POST /generate)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=0;arcSize=20;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="160" y="130" width="280" height="50" as="geometry" />
        </mxCell>

        <!-- Arrow 2→3 -->
        <mxCell id="5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;" edge="1" source="4" target="6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Box 3: Inventory files written -->
        <mxCell id="6" value="Ansible inventory files&#xa;written to disk&#xa;(all.yaml + host_vars/)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=0;arcSize=20;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="160" y="230" width="280" height="60" as="geometry" />
        </mxCell>

        <!-- Arrow 3→4 -->
        <mxCell id="7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;" edge="1" source="6" target="8" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Box 4: User triggers deploy -->
        <mxCell id="8" value="User triggers deploy&#xa;(GET /deploy + SSH credentials)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=0;arcSize=20;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="160" y="340" width="280" height="50" as="geometry" />
        </mxCell>

        <!-- Arrow 4→5 -->
        <mxCell id="9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;" edge="1" source="8" target="10" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Box 5: ansible-playbook spawned -->
        <mxCell id="10" value="ansible-playbook&#xa;subprocess spawned" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1;arcSize=20;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="160" y="440" width="280" height="50" as="geometry" />
        </mxCell>

        <!-- Arrow 5→6 -->
        <mxCell id="11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;strokeWidth=2;" edge="1" source="10" target="12" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Box 6: docker-install -->
        <mxCell id="12" value="Role: docker-install&#xa;(all nodes)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=0;arcSize=20;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="160" y="540" width="280" height="50" as="geometry" />
