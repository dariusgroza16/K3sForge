        </mxCell>

        <!-- Box 10: worker-install -->
        <mxCell id="20" value="Role: worker-install&#xa;(join worker nodes)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=0;arcSize=20;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="160" y="940" width="280" height="50" as="geometry" />
