        <!-- Box 11: Cluster ready -->
        <mxCell id="22" value="K3s Cluster Ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;arcSize=20;spacingTop=4;spacingBottom=4;" vertex="1" parent="1">
          <mxGeometry x="160" y="1040" width="280" height="50" as="geometry" />
        </mxCell>

        <!-- Dashed SSE feedback arrow from ansible-playbook back to UI -->
        <mxCell id="23" value="SSE stream&#xa;(real-time progress)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;strokeWidth=2;strokeColor=#999999;fontColor=#666666;fontSize=11;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="10" target="2" parent="1">
          <mxGeometry relative="1" as="geometry">
